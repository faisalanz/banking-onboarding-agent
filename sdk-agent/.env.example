# ---- Anthropic ----
ANTHROPIC_API_KEY=your-anthropic-api-key

# ---- Salesforce (Connected App, client credentials flow) ----
SF_DOMAIN=https://{YOUR_DOMAIN}.my.salesforce.com
SF_CLIENT_ID=your-salesforce-client-id
SF_CLIENT_SECRET=your-salesforce-client-secret

# ---- KYC mock (your live Heroku app) ----
KYC_URL=https://{YOUR_HEROKU_DOMAIN}.herokuapp.com or anywhere KYC app is deployed

# ---- Email sender (must be a Verified org-wide address; leave blank to use default sender) ----
EB_FROM_ADDRESS=valid.email@domain.com

# ---- Optional: Marcus's real-time bell notification (demo parity with the Agentforce build) ----
# Custom Notification Type Id (0ML...) - the same KYC_Decline_Alert you created
SF_NOTIF_TYPE_ID=your-salesforce-notification-type-id
# Marcus's User Id (005...)
SF_CSR_USER_ID=secondary-user-id-salesforce-id
